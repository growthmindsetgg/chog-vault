# web/.env.local — public/build-time only. NEVER place a private key here.

# RPC override. Defaults to addresses.json -> "rpc" if unset. Use Ankr to avoid
# official RPC 429-throttle.
NEXT_PUBLIC_RPC_URL=https://rpc.ankr.com/monad_testnet

# Optional: WalletConnect projectId for RainbowKit. Defaults to a placeholder
# string — WalletConnect will just be inactive without a real id.
# NEXT_PUBLIC_WC_PROJECT_ID=
